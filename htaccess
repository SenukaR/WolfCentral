<IfModule mod_headers.c>
    # 1. Fix: Missing or weak Referrer Policy
    # Tells the browser not to leak your URLs when users click links to other sites.
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # 2. Fix: Missing or invalid X-Content-Type-Options
    # Stops hackers from tricking the browser into executing malicious files.
    Header always set X-Content-Type-Options "nosniff"

    # 3. Fix: Missing Content Security Policy (CSP)
    # This acts as a bouncer, only allowing approved content to load.
    # Note: I added permissions for your Google Maps iframe and your new UI Avatars!
    Header always set Content-Security-Policy "default-src 'self'; img-src 'self' https://ui-avatars.com data:; frame-src 'self' https://www.google.com; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline';"
</IfModule>

# 4. Fix: Server banner discloses software
# Hides the Apache version number from the bottom of error pages.
ServerSignature Off